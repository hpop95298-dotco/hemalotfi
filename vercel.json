{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "client/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/index.cjs"
    },
    {
      "src": "/test-v1",
      "dest": "dist/index.cjs"
    },
    {
      "src": "/(assets|static)/(.*)",
      "dest": "/client/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "dist/index.cjs"
    }
  ]
}